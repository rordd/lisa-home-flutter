const GLASS = {
  background: "rgba(255,255,255,0.78)",
  backdropFilter: "blur(40px) saturate(180%)",
  WebkitBackdropFilter: "blur(40px) saturate(180%)",
  borderRadius: 28,
  border: "1px solid rgba(255,255,255,0.5)",
  boxShadow: "0 2px 20px rgba(0,0,0,0.04)",
};

// ═══════════════════════════════════════
// Focusable with press state + link
// ═══════════════════════════════════════
function Thumb({ children, href, style, id }) {
  const ref = useRef(null);
  const [state, setState] = useState("idle"); // idle | focused | pressed
  useEffect(() => {
    const el = ref.current;
    if (!el) return;
    const onFocus = () => setState("focused");
    const onBlur = () => setState("idle");
    el.addEventListener("focus", onFocus);
    el.addEventListener("blur", onBlur);
    return () => { el.removeEventListener("focus", onFocus); el.removeEventListener("blur", onBlur); };
  }, []);

  const handlePress = () => {
    setState("pressed");
    setTimeout(() => {
      if (href) window.open(href, "_blank");
      setState("focused");
    }, 300);
  };

  const handleKey = (e) => {
    if (e.key === "Enter" || e.key === " ") { e.preventDefault(); handlePress(); }
  };

  const scale = state === "pressed" ? 0.96 : state === "focused" ? 1.04 : 1;
  const glow = state === "focused"
    ? "0 0 0 3px rgba(0,122,255,0.5), 0 8px 30px rgba(0,0,0,0.12)"
    : state === "pressed"
    ? "0 0 0 3px rgba(0,122,255,0.7), 0 2px 8px rgba(0,0,0,0.15)"
    : "none";

  return (
    <div ref={ref} tabIndex={0} data-fid={id}
      onClick={handlePress} onKeyDown={handleKey}
      style={{
        ...style, outline: "none", cursor: "pointer",
        transform: `scale(${scale})`,
        boxShadow: glow,
        transition: "all 0.25s cubic-bezier(0.22,1,0.36,1)",
        zIndex: state !== "idle" ? 10 : "auto",
        position: "relative",
      }}
    >
      {typeof children === "function" ? children(state) : children}
    </div>
  );
}

// Simple focusable (no link)
function F({ children, onPress, style, autoFocus, id }) {
  const ref = useRef(null);
  const [f, setF] = useState(false);
  useEffect(() => { if (autoFocus) setTimeout(() => ref.current?.focus(), 100); }, [autoFocus]);
  return (
    <div ref={ref} tabIndex={0} data-fid={id}
      onFocus={() => setF(true)} onBlur={() => setF(false)}
      onClick={onPress}
      onKeyDown={e => { if (e.key === "Enter") { e.preventDefault(); onPress?.(); }}}
      style={{
        ...style, outline: "none",
        transition: "all 0.25s cubic-bezier(0.22,1,0.36,1)",
        transform: f ? "scale(1.03)" : "scale(1)",
        boxShadow: f ? "0 0 0 3px rgba(0,122,255,0.5), 0 8px 24px rgba(0,0,0,0.1)" : style?.boxShadow || "none",
        zIndex: f ? 10 : "auto",
      }}
    >{children}</div>
  );
}

// ═══════════════════════════════════════
// PLAY OVERLAY — appears on focus/press
// ═══════════════════════════════════════
function PlayOverlay({ state, label }) {
  if (state === "idle") return null;
  return (
    <div style={{
      position: "absolute", inset: 0, borderRadius: "inherit",
      background: state === "pressed"
        ? "rgba(0,0,0,0.5)"
        : "rgba(0,0,0,0.3)",
      display: "flex", flexDirection: "column",
      alignItems: "center", justifyContent: "center",
      transition: "all 0.2s",
      zIndex: 5,
    }}>
      <div style={{
        width: state === "pressed" ? 48 : 52,
        height: state === "pressed" ? 48 : 52,
        borderRadius: "50%",
        background: "rgba(255,255,255,0.95)",
        display: "flex", alignItems: "center", justifyContent: "center",
        transition: "all 0.2s",
        boxShadow: "0 2px 12px rgba(0,0,0,0.2)",
      }}>
        {label === "play" ? (
          <span style={{ fontSize: 18, marginLeft: 3, color: "#1d1d1f" }}>▶</span>
        ) : (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#1d1d1f">
            <path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/>
          </svg>
        )}
      </div>
      <div style={{
        marginTop: 10, fontSize: 13, fontWeight: 600, color: "#fff",
        letterSpacing: 0.5, opacity: state === "pressed" ? 1 : 0.8,
      }}>
        {label === "play" ? "재생하기" : "바로가기"}
      </div>
    </div>
  );
}

