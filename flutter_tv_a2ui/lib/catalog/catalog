  { id:"media-yt", name:"MediaRailCard", desc:"썸네일 레일 (클릭→재생)", intents:["유튜브 추천","음악 추천"], color:"#ff3b30" },
  { id:"media-mv", name:"MediaRailCard", desc:"포스터 레일 (클릭→상세)", intents:["영화 추천","넷플릭스 추천"], color:"#ff6482" },
  { id:"article-list", name:"ArticleListCard", desc:"기사 리스트 (행 클릭→원문)", intents:["블로그 추천","뉴스 보여줘"], color:"#34c759" },
  { id:"article-summary", name:"ArticleSummaryCard", desc:"기사 AI 요약 카드", intents:["기사 요약해줘","뉴스 핵심만"], color:"#30b0c7" },
  { id:"review-summary", name:"ReviewSummaryCard", desc:"리뷰 AI 분석 요약", intents:["맛집 리뷰","이 가게 어때"], color:"#af52de" },
  { id:"place", name:"PlaceRailCard", desc:"장소 카드 (클릭→지도)", intents:["맛집 추천","카페 추천"], color:"#ff2d55" },
  { id:"webapp", name:"WebAppCard", desc:"AI 생성 웹앱", intents:["게임 만들어줘","퀴즈"], color:"#ff9500" },
  { id:"device", name:"DeviceGridCard", desc:"IoT 기기 토글", intents:["집안 기기","조명 켜줘"], color:"#5ac8fa" },
];

export default function App() {
  const [sel, setSel] = useState("media-yt");
  const cur = CATALOG.find(c => c.id === sel);

  const preview = () => {
    switch(sel) {
      case "hero": return <HeroDataCard />;
      case "context": return <ContextCard />;
      case "media-yt": return <MediaRailCard variant="youtube" />;
      case "media-mv": return <MediaRailCard variant="movie" />;
      case "article-list": return <ArticleListCard />;
      case "article-summary": return <ArticleSummaryCard />;
      case "review-summary": return <ReviewSummaryCard />;
      case "place": return <PlaceRailCard />;
      case "webapp": return <WebAppCard />;
      case "device": return <DeviceGridCard />;
      default: return null;
    }
  };

  // spatial nav
  useEffect(() => {
    const h = e => {
      const arrows = ["ArrowUp","ArrowDown","ArrowLeft","ArrowRight"];
      if (!arrows.includes(e.key)) return;
      const els = Array.from(document.querySelectorAll("[tabindex='0']")).filter(el => {
        const r = el.getBoundingClientRect(); return r.width > 0 && r.height > 0;
      });
      const cur = document.activeElement;
      const idx = els.indexOf(cur);
      if (idx === -1 && els.length) { els[0].focus(); return; }
      const cr = cur.getBoundingClientRect();
      const cx = cr.left + cr.width / 2, cy = cr.top + cr.height / 2;
      let best = null, bestD = Infinity;
      els.forEach((el, i) => {
        if (i === idx) return;
        const r = el.getBoundingClientRect();
        const ex = r.left + r.width / 2, ey = r.top + r.height / 2;
        const dx = ex - cx, dy = ey - cy;
        let ok = false;
        if (e.key === "ArrowRight" && dx > 12) ok = true;
        if (e.key === "ArrowLeft" && dx < -12) ok = true;
        if (e.key === "ArrowDown" && dy > 12) ok = true;
        if (e.key === "ArrowUp" && dy < -12) ok = true;
        if (ok) {
          const p = (e.key === "ArrowRight" || e.key === "ArrowLeft") ? Math.abs(dx) : Math.abs(dy);
          const s = (e.key === "ArrowRight" || e.key === "ArrowLeft") ? Math.abs(dy) : Math.abs(dx);
          if (p + s * 3 < bestD) { bestD = p + s * 3; best = el; }
        }
      });
      if (best) { e.preventDefault(); best.focus(); best.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "nearest" }); }
    };
    window.addEventListener("keydown", h);
    return () => window.removeEventListener("keydown", h);
  }, []);

  return (
    <div style={{ fontFamily: FONT, background: "#f5f5f7", minHeight: "100vh", display: "flex", flexDirection: "column" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700;800&display=swap');
        * { box-sizing:border-box; margin:0; padding:0; }
        ::-webkit-scrollbar { display:none; }
        body { background:#f5f5f7; }
      `}</style>

      <div style={{ padding:"14px 24px", background:"rgba(245,245,247,0.85)", backdropFilter:"blur(20px)", borderBottom:"1px solid rgba(0,0,0,0.06)", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div style={{ display:"flex", alignItems:"center", gap:10 }}>
          <div style={{ width:30, height:30, borderRadius:9, background:"linear-gradient(135deg,#667eea,#a855f7)", display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:800, color:"#fff" }}>T</div>
          <span style={{ fontSize:16, fontWeight:700, color:"#1d1d1f" }}>TiVian catalog</span>
          <span style={{ fontSize:12, color:"#86868b" }}>v3 · clickable thumbnails</span>
        </div>
      </div>

      <div style={{ display:"flex", flex:1, overflow:"hidden" }}>
        <div style={{ width:260, borderRight:"1px solid rgba(0,0,0,0.06)", overflowY:"auto", padding:"8px 0", flexShrink:0, background:"rgba(255,255,255,0.5)" }}>
          {CATALOG.map(c => (
            <div key={c.id} onClick={() => setSel(c.id)} style={{
              padding:"12px 16px", cursor:"pointer",
              background: sel === c.id ? "rgba(0,122,255,0.05)" : "transparent",
              borderLeft: sel === c.id ? `3px solid ${c.color}` : "3px solid transparent",
            }}>
              <div style={{ display:"flex", alignItems:"center", gap:8 }}>
                <div style={{ width:8, height:8, borderRadius:3, background:c.color, flexShrink:0 }} />
                <span style={{ fontSize:13, fontWeight:600, color:"#1d1d1f" }}>{c.name}</span>
              </div>
              <div style={{ fontSize:11, color:"#86868b", marginTop:2, marginLeft:16 }}>{c.desc}</div>
              <div style={{ display:"flex", flexWrap:"wrap", gap:3, marginTop:5, marginLeft:16 }}>
                {c.intents.map((t,i) => (
                  <span key={i} style={{ fontSize:10, padding:"1px 6px", borderRadius:6, background:"rgba(0,0,0,0.04)", color:"#86868b" }}>{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div style={{ flex:1, overflowY:"auto", padding:20 }}>
          <div style={{ marginBottom:16 }}>
            <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:4 }}>
              <div style={{ width:10, height:10, borderRadius:4, background:cur.color }} />
              <span style={{ fontSize:20, fontWeight:700, color:"#1d1d1f" }}>{cur.name}</span>
            </div>
            <div style={{ fontSize:13, color:"#86868b" }}>{cur.desc}</div>
            <div style={{ display:"flex", gap:6, marginTop:8, flexWrap:"wrap" }}>
              {cur.intents.map((t,i) => (
                <span key={i} style={{ fontSize:12, padding:"3px 10px", borderRadius:10, background:"rgba(0,122,255,0.06)", color:"#007aff", fontWeight:500 }}>"{t}"</span>
              ))}
            </div>
          </div>
          <div style={{ background:"rgba(0,0,0,0.015)", borderRadius:24, padding:20, border:"1px dashed rgba(0,0,0,0.06)" }}>
            <div style={{ fontSize:11, color:"#c7c7cc", fontWeight:600, marginBottom:12, letterSpacing:1 }}>
              TV PREVIEW — 썸네일에 포커스(Tab/방향키)해 보세요
            </div>
            {preview()}
          </div>
        </div>
      </div>
    </div>
  );
}
